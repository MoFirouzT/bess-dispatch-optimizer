# Copy to `.env` (gitignored) and fill in. Only needed for the live ENTSO-E
# loader (R1.4b) and its token-gated integration test — CI never reads this.

# ENTSO-E Transparency Platform security token.
# Register at https://transparency.entsoe.eu/ → "My Account Settings" → request
# API access; the token is emailed. Host: https://web-api.tp.entsoe.eu/api
ENTSOE_API_TOKEN=

# --- TLS / corporate proxy (this machine only) -------------------------------
# If a TLS-intercepting proxy with a private CA is on the network, uv's bundled
# Python won't trust it and live fetches fail CERTIFICATE_VERIFY_FAILED. Export
# the macOS Keychain roots and point Python at them (operator setup, not code):
#
#   security find-certificate -a -p /Library/Keychains/System.keychain > ca.pem
#   security find-certificate -a -p \
#       /System/Library/Keychains/SystemRootCertificates.keychain >> ca.pem
#
# REQUESTS_CA_BUNDLE=/absolute/path/to/ca.pem   # entsoe-py uses requests
# SSL_CERT_FILE=/absolute/path/to/ca.pem        # stdlib urllib

# --- forecaster group (this machine only) ------------------------------------
# The optional `forecast` group (R2.1: LightGBM/MAPIE) needs the OpenMP runtime.
# On macOS: `brew install libomp`. Linux CI links `libgomp`, so this is a local
# operator step only, not a code dependency.
